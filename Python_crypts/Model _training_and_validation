{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNDu1VNmMaWWxjlLW9G2oBY"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"YtZihH25HnXC"},"outputs":[],"source":["import numpy as np\n","import pandas as pd\n","import math\n","import matplotlib.pyplot as plt\n","from scipy.interpolate import interp1d\n","from scipy.integrate import trapezoid\n","\n","import pickle\n","import sklearn\n","import joblib\n","import os\n","import urllib.request\n","import pickle\n","\n","from sklearn.model_selection import StratifiedKFold, GridSearchCV, KFold\n","from sklearn.base import RegressorMixin, BaseEstimator\n","from sklearn.metrics import r2_score,  mean_squared_error\n","from sklearn.utils.validation import check_is_fitted\n","import matplotlib.lines as mlines\n","from sklearn.model_selection import learning_curve\n","from sklearn.pipeline import Pipeline\n","from sklearn.preprocessing import StandardScaler\n","from sklearn.svm import SVR\n","from scipy.integrate import simpson"]},{"cell_type":"code","source":["#---------------------------------------------\n","#Obtaining SDSS filter curves for convolution\n","#--------------------------------------------\n","\n","def load_sdss_filter(band):\n","    url = f\"http://classic.sdss.org/dr7/instruments/imager/filters/{band}.dat\"\n","    data = np.loadtxt(urllib.request.urlopen(url))\n","\n","    wavelength = data[:, 0]   # Angstrom\n","    transmission = data[:, 1] # system response\n","\n","    return wavelength, transmission\n","\n","wave_r, T_r = load_sdss_filter('r')\n","wave_i, T_i = load_sdss_filter('i')\n","wave_z, T_z = load_sdss_filter('z')"],"metadata":{"id":"5IuFFM18IGC6"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# -------------------------------------------------\n","#Band integration\n","# -------------------------------------------------\n","\n","def compute_band_flux(wavelength, flux, filt_wave, filt_trans):\n","\n","    interp_func = interp1d(wavelength, flux,\n","                           bounds_error=False,\n","                           fill_value=\"extrapolate\")\n","\n","    flux_interp = interp_func(filt_wave)\n","\n","    numerator = simpson(flux_interp * filt_trans * filt_wave, filt_wave)\n","    denominator = simpson(filt_trans * filt_wave, filt_wave)\n","\n","    return numerator / denominator\n","\n","def compute_sdss_riz(obj_wave, obj_spec, filters):\n","\n","    refl = {}\n","\n","    for f, (fw, ft) in filters.items():\n","        F_obj = compute_band_flux(obj_wave, obj_spec, fw, ft)\n","\n","        refl[f] = F_obj  # ✅ NO solar division\n","\n","    # normalize at r\n","    refl_norm = {f: refl[f] / refl['r'] for f in refl}\n","\n","    colors = {\n","        \"r-i\": refl_norm['r'] - refl_norm['i'],\n","        \"r-z\": refl_norm['r'] - refl_norm['z']\n","    }\n","\n","    return refl_norm, colors"],"metadata":{"id":"SdEAi6SzIZ1K"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#---------------------------------\n","#Training data\n","#---------------------------------\n","catalogue = pd.read_excel(\"data_all_H_laser.xlsx\",\n","                          index_col=None,\n","                          header=0,\n","                          na_values=[\"NA\"],\n","                          engine=\"openpyxl\")\n","\n","sample_names = np.array(catalogue[\"Sample name\"], dtype=str)\n","ET_1AU = np.array(catalogue[\"ET_1AU\"], dtype=np.float32)\n","type = np.array(catalogue[\"type\"], dtype=str)\n","irradiation = np.array(catalogue[\"Irradiation\"], dtype=int)\n","log_ET_1AU = np.reshape(np.log10(np.array(catalogue[\"ET_1AU\"], dtype=np.float32) + 1), (-1, 1))\n","group = np.array(catalogue[\"group\"], dtype=int)"],"metadata":{"id":"IIrkhdS5KkUY"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["SDSS_wave = np.array([616, 748, 893],dtype=float)\n","\n","# Central wavelengths of SDSS bands (nm)\n","lambda_r = 616.6\n","lambda_i = 748.0\n","lambda_z = 893.2\n","\n","\n","output_df = pd.DataFrame(columns=[\n","    \"Sample name\", \"616nm\", \"748nm\", \"893nm\", \"Irradiation\"\n","])\n","\n","\n","\n","filters = {\n","    'r': (wave_r, T_r),\n","    'i': (wave_i, T_i),\n","    'z': (wave_z, T_z)\n","}\n","\n","input_data = np.zeros((len(sample_names), len(SDSS_wave) + 1), dtype=np.float32)  # +1 for band slope\n","\n","for i, sample_name in enumerate(sample_names):\n","\n","    # -----------------------------\n","    # Load lab spectrum\n","    # -----------------------------\n","    spectra = pd.read_csv(\"Data/\" + sample_name + \".csv\", header=1)\n","\n","    wavelengths = spectra[\"W\"].to_numpy() * 1000.0   # µm → nm\n","    reflectance_lab = spectra[\"R\"].to_numpy()\n","\n","    # Sort wavelengths\n","    idx = np.argsort(wavelengths)\n","    wavelengths = wavelengths[idx]\n","    reflectance_lab = reflectance_lab[idx]\n","\n","    # -----------------------------\n","    # Prepare for SDSS convolution\n","    # -----------------------------\n","    obj_wave = wavelengths * 10.0   # nm → Å\n","    obj_spec = reflectance_lab\n","\n","    # -----------------------------\n","    # Compute SDSS reflectance\n","    # -----------------------------\n","\n","    refl_norm, colors = compute_sdss_riz(\n","        obj_wave, obj_spec,\n","        filters\n","    )\n","\n","\n","    # -----------------------------\n","    # Plot SDSS points\n","    # -----------------------------\n","    wavelengths_sdss = [lambda_r, lambda_i, lambda_z]\n","    reflectance_sdss = [\n","        refl_norm['r'],\n","        refl_norm['i'],\n","        refl_norm['z']\n","    ]\n","\n","    input_data[i, :-1], input_data[i, -1] = reflectance_sdss, irradiation[i]\n","\n","\n","    # -----------------------------\n","    R_r = float(refl_norm['r'])\n","    R_i = float(refl_norm['i'])\n","    R_z = float(refl_norm['z'])\n","\n","    output_df.loc[len(output_df)] = [\n","        sample_name,\n","        R_r,\n","        R_i,\n","        R_z,\n","        irradiation[i]\n","    ]\n","\n","        #-----------------------------\n","    # Color per sample\n","    # -----------------------------\n","    color = plt.cm.tab10(i % 10)\n","\n","    # -----------------------------\n","    # Plot SDSS points\n","    # -----------------------------\n","    plt.plot(wavelengths_sdss, reflectance_sdss)\n","\n","# ------------------------------------\n","# Final plot settings\n","# ------------------------------------\n","plt.xlabel(\"Wavelength (nm)\")\n","plt.ylabel(\"Reflectance (normalized at r)\")\n","plt.title(\"Lab Spectra + SDSS r,i,z Reflectance\")\n","plt.grid(alpha=0.3)\n","\n","#plt.savefig(file_path + '/SDSS/SDSS_training_convoluted.png',\n","#            bbox_inches=\"tight\", pad_inches=0.05, dpi=150)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"n1aeK98xKm8Q","executionInfo":{"status":"ok","timestamp":1783928855443,"user_tz":-180,"elapsed":38538,"user":{"displayName":"Lakshika Palamakumbure","userId":"05035652747917428099"}},"outputId":"1ceee14a-bbc8-4cd2-b62d-1f99727f0342"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["print(input_data)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"JnLMuDW1svTf","executionInfo":{"status":"ok","timestamp":1782389629664,"user_tz":-180,"elapsed":20,"user":{"displayName":"Lakshika Palamakumbure","userId":"05035652747917428099"}},"outputId":"82939403-33a9-4546-820e-868cfa881d4f","collapsed":true},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["[[ 1.          1.1163508   0.8063694   2.        ]\n"," [ 1.          1.1681808   0.86239165  2.        ]\n"," [ 1.          1.2066479   0.9308087   2.        ]\n"," [ 1.          1